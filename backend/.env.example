PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=core
DB_PASSWORD=corepassword
DB_NAME=coreinventory

DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=supersecret_key_change_in_production
JWT_EXPIRED_IN=15m
JWT_REFRESH_SECRET=refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRED_IN=7d

# Email / SendGrid (mocked for dev)
SENDGRID_API_KEY=mocked
EMAIL_FROM=noreply@coreinventory.local
